<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Gestión de Empleados</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" />

    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: 700; letter-spacing: 0.5px; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        .table thead th { background-color: #0d6efd; color: #fff; font-weight: 600; }
        .badge-activo { background-color: #198754; }
        .badge-baja  { background-color: #6c757d; }
        .page-item.active .page-link { background-color: #0d6efd; border-color: #0d6efd; }
        footer { font-size: .85rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Empleados" asp-action="Index">
                <i class="bi bi-people-fill me-2"></i>Gestión de Empleados
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Empleados" asp-action="Index">
                            <i class="bi bi-house me-1"></i>Inicio
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Empleados" asp-action="Create">
                            <i class="bi bi-person-plus me-1"></i>Nuevo Empleado
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container my-4">
        @if (TempData["Mensaje"] is not null)
        {
            var tipo = TempData["TipoMensaje"]?.ToString() ?? "info";
            <div class="alert alert-@tipo alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="text-center text-muted py-3 border-top bg-white">
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmzS7GIwYSGBF2WBECbGUYkVi8u"
            crossorigin="anonymous"></script>

            @RenderSection("Scripts", required: false)
</body>
</html>
